{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "sourceMap": true,
    "tsBuildInfoFile": "dist/tsconfig.build.tsbuildinfo"
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.test-d.ts"]
}
